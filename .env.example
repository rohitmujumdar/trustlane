# Copy to .env and fill in. The demo runs fine with all of this left blank
# (it falls back to a mock vault), so you only need this to wire real 1Password.

# 1Password service account token. Create one in your 1Password account under
# Developer > Service Accounts, then install the SDK: pip install onepassword-sdk
OP_SERVICE_ACCOUNT_TOKEN=

# Audit log signing. Use a real random value anywhere it matters.
TRUSTGATE_SIGNING_KEY=dev-insecure-key
TRUSTGATE_AUDIT_LOG=audit.log.jsonl
