# Copy to .env and fill in. Everything here can stay blank — the demo falls back
# to a mock vault and a dev signing key, so it runs with zero setup. You only
# need these to wire the real 1Password vault.

# 1Password service account token. Create one under Developer > Service Accounts,
# then: pip install onepassword-sdk
OP_SERVICE_ACCOUNT_TOKEN=

# The secret reference the gate resolves on ALLOW, e.g.
#   op://TrustLane/ExpediaPayment/credential
TRUSTLANE_SECRET_REF=op://TrustLane/ExpediaPayment/credential

# Key used to sign inbound delegation tokens (HMAC stand-in for issuer keypair).
TRUSTLANE_DELEGATION_KEY=dev-delegation-key
